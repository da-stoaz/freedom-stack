{
  "name": "freedom-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "payload": "pnpm exec payload",
    "generate:types": "pnpm exec payload generate:types",
    "generate:importmap": "pnpm exec payload generate:importmap",
    "payload:sync": "pnpm exec payload generate:importmap && pnpm exec payload generate:types",
    "seed": "tsx src/scripts/seed.ts",
    "postinstall": "echo 'Skipping Payload codegen during install; run pnpm payload:sync when schema/admin components change.'"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.72.0",
    "@payloadcms/next": "3.72.0",
    "@payloadcms/richtext-lexical": "3.72.0",
    "@payloadcms/ui": "3.72.0",
    "graphql": "^16.8.1",
    "next": "^15.0.0",
    "nodemailer": "^6.10.0",
    "payload": "3.72.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
